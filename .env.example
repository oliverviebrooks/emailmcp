# Copy to .env and fill in your values.

# IMAP (incoming mail)
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993

# SMTP (outgoing mail)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587

# Credentials
EMAIL_USER=you@gmail.com
EMAIL_PASSWORD=your-app-password   # Gmail: use an App Password, not your account password

# Optional: display name for outbound mail
# EMAIL_FROM=Your Name <you@gmail.com>
